{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/chinese-exhibition-template.json",
  "title": "Chinese Digital Exhibition Template Content Schema",
  "description": "Lightweight JSON schema for v3.0 reusable Chinese digital exhibition template. Use as authoring checklist, not runtime validator. Field names follow the project-agnostic convention extracted from v2.9-real-source-rights-audit.",
  "type": "object",
  "required": ["exhibition", "sections", "artifacts", "glossary", "sources", "rightsNote"],
  "additionalProperties": false,
  "properties": {
    "exhibition": {
      "type": "object",
      "required": ["title", "subtitle", "description", "version", "liveUrl"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "展览主标题。一句话说清展览主题。"
        },
        "subtitle": {
          "type": "string",
          "minLength": 1,
          "description": "展览副标题。说明展览视角或问题。"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "展览一句话描述。出现在 hero 区。"
        },
        "version": {
          "type": "string",
          "pattern": "^v\\d+\\.\\d+(-[a-z0-9-]+)?$",
          "description": "版本号。形如 v3.0、v3.1-real-pilot。"
        },
        "liveUrl": {
          "type": "string",
          "format": "uri",
          "description": "部署后的 GitHub Pages URL。"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "pilot", "stable", "archived"],
          "description": "展览当前状态。pilot 不部署；stable 才上线。"
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "description": "展区列表。推荐 4 个。",
      "items": {
        "type": "object",
        "required": ["id", "kicker", "title", "body", "takeaway"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "section 锚点 id。仅小写字母数字连字符。"
          },
          "kicker": {
            "type": "string",
            "minLength": 1,
            "description": "section 上方一行短引子。说明 section 视角。"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "section 标题。"
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "description": "section 正文。200–600 字。"
          },
          "takeaway": {
            "type": "string",
            "minLength": 1,
            "description": "section 结尾一句 takeaway。观众带走什么。"
          },
          "viewerAction": {
            "type": "string",
            "description": "可选。给观众的引导动作。"
          },
          "deepReading": {
            "type": "object",
            "description": "可选。深度阅读模块。",
            "additionalProperties": false,
            "properties": {
              "label": {"type": "string"},
              "body": {"type": "string"}
            }
          },
          "materialEvidence": {
            "type": "object",
            "description": "可选。材料证据模块。",
            "additionalProperties": false,
            "properties": {
              "label": {"type": "string"},
              "body": {"type": "string"}
            }
          },
          "visualThinking": {
            "type": "object",
            "description": "可选。视觉思维模块。",
            "additionalProperties": false,
            "properties": {
              "label": {"type": "string"},
              "body": {"type": "string"}
            }
          },
          "researchModel": {
            "type": "object",
            "description": "可选。研究模型模块。",
            "additionalProperties": false,
            "properties": {
              "label": {"type": "string"},
              "body": {"type": "string"}
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "description": "展品列表。推荐 4 张。",
      "items": {
        "type": "object",
        "required": ["id", "title", "image", "alt", "caption", "sourceNote", "creditLine"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "title": {"type": "string", "minLength": 1},
          "image": {
            "type": "string",
            "description": "图片路径或 URL。"
          },
          "alt": {
            "type": "string",
            "minLength": 1,
            "description": "图片 alt 文本。无障碍必填。"
          },
          "caption": {
            "type": "string",
            "minLength": 1,
            "description": "图注。"
          },
          "sourceNote": {
            "type": "string",
            "minLength": 1,
            "description": "来源说明（哪来的）。"
          },
          "creditLine": {
            "type": "string",
            "minLength": 1,
            "description": "版权 / 署名行。"
          },
          "viewingNote": {
            "type": "string",
            "description": "可选。观众观看提示。"
          },
          "origin": {
            "type": "string",
            "enum": ["collection", "manuscript", "platform-screenshot", "project-generated", "metadata"],
            "description": "展品来源分类，用于 source manifest。"
          }
        }
      }
    },
    "glossary": {
      "type": "array",
      "minItems": 1,
      "description": "术语表。推荐 6 个。每个 50–100 字。",
      "items": {
        "type": "object",
        "required": ["term", "definition"],
        "additionalProperties": false,
        "properties": {
          "term": {"type": "string", "minLength": 1},
          "definition": {
            "type": "string",
            "minLength": 50,
            "maxLength": 200,
            "description": "50–200 字。解释观众为什么需要知道它。"
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "description": "来源链接列表。",
      "items": {
        "type": "object",
        "required": ["label", "url", "note"],
        "additionalProperties": false,
        "properties": {
          "label": {"type": "string", "minLength": 1},
          "url": {"type": "string", "format": "uri"},
          "note": {"type": "string", "minLength": 1},
          "accessedAt": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "访问日期 YYYY-MM-DD。"
          }
        }
      }
    },
    "rightsNote": {
      "type": "string",
      "minLength": 1,
      "description": "展览全局权利说明。写在 README 或 footer。"
    }
  }
}